<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>my diary</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *{
            margin:0; 
            padding: 0;
            box-sizing: border-box;
        }

        .diary-container {
            max-width: 860px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .header{
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid white;
            margin-bottom: 2rem;
        }

        .header-title {
            font-family: 'Lora', serif;
            font-size: 1.75rem;
            font-weight: 700;
            color: #2d2a24;
            letter-spacing: -0.02em;
        }

        .header-title span {
            color: #a0937d;
            font-weight: 400;
        }

        .header-actions {
            display: flex;
            gap:0.75rem;
            align-items:center;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
            cursor: pointer;
            border: none;
            text-decoration: none;
        }

        .btn-primary{
                   background: #2d2a24;
            color: #faf6ef;
        }
        .btn-primary:hover {
            background: #1a1814;
        }
        .btn-ghost {
            background: transparent;
            color: #8B6914;
            border: 1px solid #e8e0d4;
        }
        .btn-ghost:hover {
            background: #f0ebe1;
        }
        .btn-write {
            background: #8B6914;
            color: white;
            font-size: 0.9375rem;
            padding: 0.625rem 1.25rem;
            border-radius: 0.5rem;
            font-weight: 600;
        }
        .btn-write:hover {
            background: #7a5d12;
        }

         .btn-logout {
            background: transparent;
            color: #a0937d;
            font-size: 0.8125rem;
            padding: 0.375rem 0.75rem;
            border: 1px solid #e8e0d4;
            border-radius: 0.375rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-logout:hover {
            color: #c0392b;
            border-color: #c0392b;
        }
        .entry-card {
            background: #ffffff;
            border: 1px solid #e8e0d4;
            border-radius: 0.75rem;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.2s ease;
            cursor: pointer;
            position: relative;
        }
        .entry-card:hover {
            border-color: #c4b8a8;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            transform: translateY(-1px);
        }
        .entry-meta {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .entry-date {
            font-size: 0.75rem;
            color: #a0937d;
            font-weight: 500;
            letter-spacing: 0.02em;
        }

        .entry-title {
            font-family: 'Lora', serif;
            font-size: 1.125rem;
            font-weight: 600;
            color: #2d2a24;
            margin-bottom: 0.375rem;
            line-height: 1.4;
        }

        .entry-preview{
            font-size: 0.87rem;
            color:#6b5e4e;
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .entry-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1rem;
            padding-top: 0.75rem;
            border-top: 1px solid #f0ebe1;
        }

        .entry-actions button {
            font-size: 0.75rem;
            background: none;
            border: none;
            cursor: pointer;
            color: #a0937d;
            font-weight: 500;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            transition: all 0.15s;
        }
        .entry-actions .edit-btn:hover {
            color: #8B6914;
            background: #faf6ef;
        }
        .entry-actions .delete-btn:hover {
            color: #c0392b;
            background: #fef2f2;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background-color: white;
            border: 1px solid #e8e0d4;
            border: 0.75rem;
        }

        .empty-state svg {
            margin: 0 auto 1rem;
            color: #c4b8a8;
        }

        .empty-state h3{
            font-family: 'Lora', serif;
            font-size: 1.25rem;
            color: #2d2a24;
            margin-bottom: 0.5rem;
        }

        .empty-state p{
            font-size: 0.875rem;
            color: #a0937d;
        }

        .empty-state .btn{
            margin-top: 1.25rem;
        }

        .section-title {
            font-family: 'Lora', serif;
            font-size: 0.875rem;
            font-weight: 600;
            color: #a0937d;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <div class="diary-container">
        <header class="header-title">
            <div class="header-actions">my diary</div>
            <div>
                <a href="/settings" class="btn-logout" style="border-color: white; color:#8B6914;">settings</a>
                <a href="/logout">sign out</a>
            </div>
        </header>

        <div>
            <div class="section-title"><%= entries.length %><% entries.length === 1 ? 'entry' : 'entries'%></div>
            <a href="/write" class="btn btn-write">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14" />
                </svg>
                Write
            </a>
        </div>

        <% if(entries.length === 0) { %>
            <div>
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12" />
                    <line x1="9" y1="15" x2="15" y2="15" />
                </svg>
                <h3>Your Diary is empty</h3>
                <p>Write down your first thought, memory etc</p>
                <a href="/write" class="btn btn-primary" style="display:inline-flex">Write your first entry</a>
            </div>
            <% } %>

            <% entries.forEach(entry => { %>
                <div class="entry-card" onclick="window.location='/entry/<%= entry._id %>'">
                    <div class="entry-meta">
                        <span class="entry-date"><%= new Date(entry.createdAt).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    <span class="entry-mood"><%= entry.mood %></span>                    </div>
                </div>
                 <div class="entry-title"><%= entry.title %></div>
                <div class="entry-preview"><%= entry.content %></div>
                <div class="entry-actions" onclick="event.stopPropagation()">
                    <button class="edit-btn" onclick="window.location='/entry/<%= entry._id %>'">open & edit</button>
                    <form action="/entries/delete/<%= entry._id %>" method="POST" onsubmit="return confirm('Delete this entry forever?')" style="display:inline;">
                        <button type="submit" class="delete-btn">delete</button>
                    </form>
                </div>
            </div>
            <% }) %>
    </div>
</body>
</html>