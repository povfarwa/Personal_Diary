<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>sign in — my diary</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            font-family: 'Inter', sans-serif;
            background: #faf6ef;
            color: #2d2a24;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .auth-card {
            background: white;
            border: 1px solid #e8e0d4;
            border-radius: 1rem;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 300px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.04);
        }

        .auth-title {
            font-family: 'Lora', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: #2d2a24;
            text-align: center;
            margin-bottom: 0.25rem;
        }

        .auth-subtitle {
            font-size: 0.8125rem;
            color: #a0937d;
            text-align: center;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label{
            display: block;
            font-size: 0.75rem;
            font-weight: 600;
            color: #8B6914;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.375rem;
        }

        .form-group input:focus {
            border-color: #8B6914;
            background-color: white;
        }

        .btn-submit {
            width: 100%;
            background: #2d2a24;
            color: #faf6ef;
            font-size: 0.9375rem;
            font-weight: 600;
            padding: 0.75rem;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 0.5rem;
        }

        .btn-submit:hover {
            background: #1a1814;
        }
        .auth-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.8125rem;
            color: #a0937d;
        }
        .auth-footer a {
            color: #8B6914;
            text-decoration: none;
            font-weight: 600;
        }
        .auth-footer a:hover {
            text-decoration: underline;
        }
        .error-msg {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
            font-size: 0.8125rem;
            padding: 0.625rem 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 1.25rem;
            text-align: center;
        }
        .diary-icon {
            text-align: center;
            margin-bottom: 0.5rem;
        }
    </style>
</head>
<body>
     <div class="auth-card">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8B6914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H602 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z">
            <polyline points="14 2 14 8 20 8">
            <line x1="16" y1="13" x2="8" y2="13">
            <line x1="16" y1="17" x2="8" y2="17">
            <polyline points="10 9 9 9 8 9">
        </svg>
    </div>

    <div class="auth-card">
        <div class="diary-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
            </svg>
        </div>
    </div>

    <div class="auth-title">my diary</div>
    <div class="auth-subtitle">sign in to continue</div>

    <% if(error) { %>
        <div class="error-msg"><%= error %></div>
    <% } %>

    <form action="/register" method="POST">
        <div class="form-group">
            <label for="username">Username</label>
            <input type="text" name="username" id="username" placeholder="choose a username" required>
        </div>
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" name="password" id="password" placeholder="choose a password" required>
        </div>
        <button type="submit" class="btn-submit">Sign in</button>
    </form>

    <div class="auth-footer">
        Dont have an account? <a href="/register">Create Account</a>
    </div>
</body>
</html>